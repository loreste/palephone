# Pale Server configuration
#
# Copy to .env (docker compose reads it automatically), or run
# ./scripts/generate-secrets.sh to create a .env with strong random secrets.

# ── Required secrets (min 24 characters each) ───────────────────────────────
# Generate with: openssl rand -base64 32
PALE_SERVER_TOKEN=
PALE_ADMIN_PASSWORD=
PALE_STORAGE_KEY=
# PostgreSQL password (use openssl rand -hex 32 — hex avoids characters that
# need quoting in connection strings)
POSTGRES_PASSWORD=
# Shared secret between pale-server and coturn
TURN_SECRET=

# ── Common settings ─────────────────────────────────────────────────────────
# Admin account name (default: admin)
#PALE_ADMIN_USERNAME=admin

# Public hostname/IP clients use to reach SIP. REQUIRED for remote clients —
# without it the registrar is advertised as 127.0.0.1.
#PALE_SIP_EXTERNAL_ADDR=sip.example.com:5060

# HTTP API bind address (default 127.0.0.1:8080; docker-compose overrides to 0.0.0.0:8080)
#PALE_HTTP_ADDR=0.0.0.0:8080
# HTTPS for the API (strongly recommended when bound to a non-loopback address)
#PALE_HTTP_TLS_CERT=/path/to/fullchain.pem
#PALE_HTTP_TLS_KEY=/path/to/privkey.pem

# ── SIP transports ──────────────────────────────────────────────────────────
# SIP bind address (default 0.0.0.0:5060)
#PALE_SIP_ADDR=0.0.0.0:5060
# SIP TLS turns on automatically when both cert and key are set.
# Set PALE_SIP_TLS=true/false to force it on/off.
#PALE_SIP_TLS_CERT=/path/to/fullchain.pem
#PALE_SIP_TLS_KEY=/path/to/privkey.pem
#PALE_SIP_TLS_PORT=5061
# Require encrypted media (default true)
#PALE_SIP_SRTP=true
# Plain UDP transport (default: on unless TLS is enabled)
#PALE_SIP_UDP=true
#PALE_SIP_TCP=false

# ── NAT traversal ───────────────────────────────────────────────────────────
# Comma-separated STUN servers. Default uses Google's public STUN — point this
# at your own server if that is a privacy concern.
#PALE_STUN_SERVERS=stun:stun.l.google.com:19302
#PALE_TURN_SERVER=turn:your.server.ip:3478
#PALE_TURN_TRANSPORT=udp
#PALE_TURN_REALM=pale.local

# ── Persistence ─────────────────────────────────────────────────────────────
# PostgreSQL connection string. Without it the server uses local SQLite in
# PALE_DATA_DIR (fine for a single node; use PostgreSQL in production).
#PALE_DATABASE_URL=host=localhost user=pale password=... dbname=pale
#PALE_PG_MAX_CONNECTIONS=10
#PALE_DATA_DIR=./pale-data

# ── Event bus integrations ─────────────────────────────────────────────────
# Optional NATS server for server-side event consumers. docker-compose defaults
# this to nats://nats:4222 and publishes JSON on pale.events.<event_type>.
#NATS_URL=nats://localhost:4222

# ── Tuning / logging ────────────────────────────────────────────────────────
#PALE_RATE_LIMIT_RPS=100
#PALE_MAX_UPLOAD_BYTES=104857600
#PALE_LOG_JSON=false
#RUST_LOG=info
