# Pale Server configuration
#
# Copy to .env (docker compose reads it automatically), or run
# ./scripts/generate-secrets.sh to create a .env with strong random secrets.
# For production, also set the "Production hostnames" section below.
# See docs/deploy/PRODUCTION.md.

# ── Required secrets (min 24 characters each) ───────────────────────────────
# Generate with: openssl rand -base64 32
PALE_SERVER_TOKEN=
PALE_ADMIN_PASSWORD=
PALE_STORAGE_KEY=
# PostgreSQL password (use openssl rand -hex 32 — hex avoids characters that
# need quoting in connection strings)
POSTGRES_PASSWORD=
# Shared secret between pale-server and coturn
TURN_SECRET=

# ── Production hostnames (required for docker-compose.prod.yml) ─────────────
# Public DNS name clients use for the HTTP API (and Caddy ACME if enabled).
#PALE_PUBLIC_HOSTNAME=pale.example.com
# Public SIP addresses advertised to clients (never leave these as loopback).
#PALE_SIP_EXTERNAL_ADDR=pale.example.com:5060
#PALE_SIP_TLS_EXTERNAL_ADDR=pale.example.com:5061
# Client-facing TURN URI (must be reachable from remote clients, not 127.0.0.1).
#PALE_TURN_SERVER=turn:pale.example.com:3478
# Public IPv4 of the host running coturn (required in production overlay).
#TURN_EXTERNAL_IP=203.0.113.10
# NATS auth token (required by docker-compose.prod.yml).
#NATS_TOKEN=
# Directory with fullchain.pem and privkey.pem (default ./certs).
#CERTS_DIR=./certs

# ── Common settings ─────────────────────────────────────────────────────────
# Admin account name (default: admin)
#PALE_ADMIN_USERNAME=admin

# HTTP API bind address (default 127.0.0.1:8080; docker-compose overrides to 0.0.0.0:8080)
#PALE_HTTP_ADDR=0.0.0.0:8080
# HTTPS for the API (strongly recommended when bound to a non-loopback address)
#PALE_HTTP_TLS_CERT=/path/to/fullchain.pem
#PALE_HTTP_TLS_KEY=/path/to/privkey.pem

# ── SIP transports ──────────────────────────────────────────────────────────
# Built-in REGISTER/PBX path. Docker images do not include native-pjsip.
#PALE_SIP_BACKEND=udp-parser
# SIP bind address (default 0.0.0.0:5060)
#PALE_SIP_ADDR=0.0.0.0:5060
# SIP TLS turns on automatically when both cert and key are set.
# Set PALE_SIP_TLS=true/false to force it on/off.
#PALE_SIP_TLS_CERT=/path/to/fullchain.pem
#PALE_SIP_TLS_KEY=/path/to/privkey.pem
#PALE_SIP_TLS_PORT=5061
# Public TLS registrar address returned to clients (default derives from PALE_SIP_EXTERNAL_ADDR + TLS port)
#PALE_SIP_TLS_EXTERNAL_ADDR=sip.example.com:5061
# Require encrypted media (default true)
#PALE_SIP_SRTP=true
# TCP is enabled by default for the built-in parser. UDP is disabled unless explicitly enabled.
#PALE_SIP_TCP=true
#PALE_SIP_UDP=false
# UDP requires an explicit safety override and should be treated as a development/fallback transport only.
#PALE_ALLOW_INSECURE_SIP_UDP=0

# ── NAT traversal ───────────────────────────────────────────────────────────
# Comma-separated STUN servers. Default uses Google's public STUN — point this
# at your own server if that is a privacy concern. Production overlay leaves
# this empty unless you set it (prefer self-hosted or coturn STUN).
#PALE_STUN_SERVERS=stun:stun.l.google.com:19302
#PALE_TURN_SERVER=turn:your.server.ip:3478
#PALE_TURN_TRANSPORT=udp
#PALE_TURN_REALM=pale.local

# ── Meetings (LiveKit SFU) ──────────────────────────────────────────────────
# Required for multi-party audio/video. Without these, conference signaling
# works but there is no SFU media path.
#PALE_LIVEKIT_URL=ws://livekit:7880
#PALE_LIVEKIT_API_KEY=devkey
#PALE_LIVEKIT_API_SECRET=secret-must-be-at-least-32-characters-long
# When true, multi-party join fails if LiveKit is not configured.
#PALE_LIVEKIT_REQUIRED=false

# ── Malware scanning (ClamAV / YARA) ───────────────────────────────────────
#PALE_CLAMAV_HOST=clamav:3310
# Optional host `yara` binary + rules file for additional scan on upload
#PALE_YARA_RULES=/etc/pale-server/rules.yar
# When true, uploads are blocked if ClamAV/YARA is missing or unreachable.
#PALE_ATP_REQUIRED=false

# ── Identity ────────────────────────────────────────────────────────────────
# PEM CA bundle for OIDC discovery/token/JWKS TLS (enterprise IdP pinning)
#PALE_OIDC_CA_BUNDLE=/etc/pale-server/oidc-ca.pem
# Require a second admin session for secret-generation APIs
#PALE_REQUIRE_DUAL_ADMIN=true

# ── Object storage (S3 / MinIO) ──────────────────────────────────────────────
#PALE_S3_BUCKET=pale
#PALE_S3_REGION=us-east-1
#PALE_S3_ENDPOINT=http://minio:9000
#PALE_S3_ACCESS_KEY=paleminio
#PALE_S3_SECRET_KEY=

# ── Persistence ─────────────────────────────────────────────────────────────
# PostgreSQL connection string. Without it the server uses local SQLite in
# PALE_DATA_DIR (fine for a single node; use PostgreSQL in production).
#PALE_DATABASE_URL=host=localhost user=pale password=... dbname=pale
#PALE_PG_MAX_CONNECTIONS=10
#PALE_DATA_DIR=./pale-data

# ── Event bus integrations ─────────────────────────────────────────────────
# Optional NATS server for server-side event consumers. docker-compose defaults
# this to nats://nats:4222 and publishes JSON on pale.events.<event_type>.
# Production overlay requires NATS_TOKEN and uses nats://:token@nats:4222.
#NATS_URL=nats://localhost:4222
#NATS_TOKEN=

# ── Governance automation ──────────────────────────────────────────────────
# Optional scheduled retention enforcement. Unset/0 disables it; values below
# 60 seconds are clamped to 60. Use 86400 for daily enforcement.
# Production overlay defaults this to 86400.
#PALE_RETENTION_ENFORCEMENT_INTERVAL_SECS=86400
#PALE_RETENTION_ENFORCEMENT_RUN_ON_STARTUP=false

# ── Tuning / logging ────────────────────────────────────────────────────────
#PALE_RATE_LIMIT_RPS=100
#PALE_MAX_UPLOAD_BYTES=104857600
#PALE_LOG_JSON=false
#RUST_LOG=info
