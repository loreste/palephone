# Regulated mid-market profile — copy values into .env after generate-secrets.
#
#   ./scripts/generate-secrets.sh
#   cat docs/deploy/regulated-midmarket.env.example >> .env
#   # then set real IdP / hostname values
#
# See: docs/MILESTONES.md (M1), docs/deploy/PRODUCTION.md,
#      docs/deploy/sso-oidc.md, docs/deploy/dlp-lab.md

# ── Required secrets (from generate-secrets.sh; min 24 chars) ───────────────
# PALE_SERVER_TOKEN=
# PALE_ADMIN_PASSWORD=
# PALE_STORAGE_KEY=
# POSTGRES_PASSWORD=
# TURN_SECRET=
# NATS_TOKEN=                    # required for docker-compose.prod.yml

# ── Public hostnames (production) ───────────────────────────────────────────
# PALE_PUBLIC_HOSTNAME=pale.example.com
# PALE_SIP_EXTERNAL_ADDR=pale.example.com:5060
# PALE_SIP_TLS_EXTERNAL_ADDR=pale.example.com:5061
# PALE_TURN_SERVER=turn:pale.example.com:3478
# TURN_EXTERNAL_IP=203.0.113.10

# ── SIP (prefer TLS + SRTP) ─────────────────────────────────────────────────
PALE_SIP_BACKEND=udp-parser
PALE_SIP_TCP=true
PALE_SIP_UDP=false
PALE_SIP_SRTP=true
# PALE_SIP_TLS=true
# PALE_SIP_TLS_CERT=/certs/fullchain.pem
# PALE_SIP_TLS_KEY=/certs/privkey.pem

# ── Identity / admin control ────────────────────────────────────────────────
PALE_REQUIRE_DUAL_ADMIN=true
# PEM bundle for enterprise IdP TLS (optional but recommended)
# PALE_OIDC_CA_BUNDLE=/etc/pale-server/oidc-ca.pem
# Shared auth sessions across API replicas require Postgres (always on when
# PALE_DATABASE_URL is set). See docs/deploy/ha.md.
# PALE_DATABASE_URL=postgres://pale:...@postgres:5432/pale

# ── Malware (ATP) — enable compose --profile atp in production ──────────────
# PALE_CLAMAV_HOST=clamav:3310
PALE_ATP_REQUIRED=true

# ── Object storage — enable compose --profile storage ────────────────────────
# PALE_S3_BUCKET=pale
# PALE_S3_REGION=us-east-1
# PALE_S3_ENDPOINT=http://minio:9000
# PALE_S3_ACCESS_KEY=
# PALE_S3_SECRET_KEY=

# ── Meetings SFU — enable compose --profile meetings when multi-party ───────
# PALE_LIVEKIT_URL=ws://livekit:7880
# PALE_LIVEKIT_API_KEY=
# PALE_LIVEKIT_API_SECRET=
# Fail closed when SFU is mandatory for your tenant:
# PALE_LIVEKIT_REQUIRED=true

# ── Retention enforcement (seconds; 0 = disabled) ───────────────────────────
PALE_RETENTION_ENFORCEMENT_INTERVAL_SECS=3600
PALE_RETENTION_ENFORCEMENT_RUN_ON_STARTUP=true

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info
# PALE_LOG_JSON=true

# ── Post-deploy checklist (not env vars) ────────────────────────────────────
# 1. Configure OIDC: docs/deploy/sso-oidc.md
# 2. Create DLP block policy: docs/deploy/dlp-lab.md
# 3. Create CA policy require_mfa=true via admin UI or API
# 4. ./scripts/smoke-test.sh with PALE_ADMIN_TOKEN
# 5. ./scripts/export-evidence-pack.sh
# 6. GET /v1/admin/enterprise-integrations/validation — no silent greens
