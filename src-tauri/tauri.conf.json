{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pale",
  "version": "0.1.5",
  "identifier": "com.pale.softphone",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pale",
        "width": 380,
        "height": 640,
        "minWidth": 320,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
